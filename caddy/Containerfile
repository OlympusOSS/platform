# Custom Caddy build with mholt/caddy-ratelimit module.
#
# The standard caddy:2-alpine image does not include the caddy-ratelimit module,
# which is required for per-IP rate limiting on CIAM login routes (SR-CADDY-1).
# This Containerfile uses xcaddy to build a custom Caddy binary with the module
# included, then packages it into a minimal Alpine image.
#
# Module: github.com/mholt/caddy-ratelimit
# Pinned version: v0.1.0 (pinned 2026-04-05, SR-CADDY-2 / platform#47)
# Full commit SHA: 12435ecef5dbb1b137eb68002b85d775a9d5cdb2 (supply-chain traceability — DA condition)
# Reference: https://github.com/mholt/caddy-ratelimit
#
# To upgrade: check https://github.com/mholt/caddy-ratelimit/releases for a newer
# tagged release, update the version below, and update the pinned date above.
# Always verify the module is present after rebuild (caddy list-modules | grep rate_limit).

FROM docker.io/caddy:2-builder-alpine AS builder

RUN xcaddy build \
    --with github.com/mholt/caddy-ratelimit@v0.1.0

FROM docker.io/caddy:2-alpine

COPY --from=builder /usr/bin/caddy /usr/bin/caddy
