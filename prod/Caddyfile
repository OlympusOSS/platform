# Production Caddyfile — reverse proxy with TLS (ACME) and per-IP rate limiting.
#
# RATE LIMIT KEY NOTE (SR-CADDY-5 / Security V1):
# The rate limit keys on {http.request.remote.host} (TCP peer address, port stripped).
# In the current direct-connect topology (no proxy in front of Caddy) this correctly
# identifies the client IP. If a load balancer, CDN, or reverse proxy is ever placed
# in front of Caddy, ALL traffic will share the proxy's IP as the rate limit key,
# effectively disabling per-IP protection. In that case, the configuration MUST be
# updated to use `trusted_proxies` + {http.request.header.X-Forwarded-For} before
# traffic flows through the proxy.
#
# PROXY-IN-FRONT REQUIREMENTS (if topology changes):
#   - The key placeholder syntax (e.g. {http.request.header.X-Forwarded-For}) MUST be
#     verified against the installed caddy-ratelimit module version before deploying.
#     Run `caddy validate` with the updated Caddyfile — do not copy the placeholder
#     verbatim without confirming it is valid for the module version in use.
#   - Set `trusted_proxies` to the specific CIDR of the upstream proxy ONLY.
#     NEVER use `trusted_proxies 0.0.0.0/0` — this trusts all source IPs, enabling
#     any client to spoof X-Forwarded-For and bypass per-IP rate limiting entirely.
#
# RESIDUAL RISKS (accepted, documented per Security review):
# - Distributed brute force (IP rotation, botnet): this control targets single-IP
#   attacks only. An attacker with N IPs gets N×30 attempts/min. Distributed attack
#   mitigation (fail2ban, CDN bot management, account velocity limits) is out of scope.
# - IPv6 /64 prefix bypass: a /64 prefix contains ~18 quintillion addresses. An
#   attacker can rotate within a prefix with each address appearing as a distinct key.
#   Subnet-level limiting is not configured. Monitor production logs; revisit if abuse
#   is observed.
# - In-memory counters reset on Caddy restart: a restart grants a fresh burst window.
#   Accepted at current single-node scale.

{
	email {$ACME_EMAIL:noreply@example.com}
}

# Security headers snippet — applied to all site blocks.
# HSTS is included in production: all traffic is HTTPS via Caddy's ACME TLS.
# max-age=31536000 (1 year) with includeSubDomains matches the Security Expert's
# requirement (platform#18). Preload is intentionally omitted pending HSTS
# preload list submission — add "preload" and submit once confirmed stable.
(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}

# Site
{$SITE_PUBLIC_URL} {
	import security_headers
	reverse_proxy site:3000
}

# CIAM — Customer Identity
{$CIAM_HERA_PUBLIC_URL} {
	import security_headers

	# Rate limiting on login POST paths (SR-CADDY-1):
	# 5 requests per 10 seconds per source IP (30 attempts/min max).
	# Applies before requests reach Hera, providing a network-layer backstop
	# during DB outages when checkLockout() fails open.
	# Does NOT rate-limit GET page loads, static assets, or health checks.
	# Module: github.com/mholt/caddy-ratelimit (see platform/caddy/Containerfile)
	rate_limit {
		zone login_limit {
			match {
				method POST
				path /login* /self-service/login*
			}
			key {http.request.remote.host}
			events 5
			window 10s
		}
	}

	# Block external access to the HIBP policy webhook endpoint (Security Condition 1 — platform#12)
	# This endpoint receives plaintext passwords from Kratos in block mode (V2) and must be
	# internal-only. Even in V1 (warn mode), the route exists in Hera and must not be
	# externally reachable.
	@policy_password {
		path /api/policy/password*
	}
	respond @policy_password 404

	reverse_proxy ciam-hera:3000
}

{$CIAM_HYDRA_PUBLIC_URL} {
	import security_headers
	reverse_proxy ciam-hydra:5002
}

{$CIAM_ATHENA_PUBLIC_URL} {
	import security_headers
	# Transport settings for Athena RSC streaming (athena#109):
	# Next.js RSC maintains a long-lived upstream connection for client-side
	# navigation updates. Without explicit keepalive and read_timeout settings,
	# Caddy closes idle connections before RSC streaming completes, causing
	# chunk 3794 (Next.js router/RSC connection module) to throw
	# "Error: Connection closed" and block React hydration entirely.
	#
	# keepalive 65s: exceeds the 60s TCP idle timeout common on intermediate
	#   network equipment — keeps the RSC streaming connection alive.
	# keepalive_idle_conns 10: prevents connection churn under concurrent loads.
	# dial_timeout 10s: bounds upstream TCP connect time.
	# response_header_timeout 60s: bounds wait for first response header.
	# read_timeout 120s: covers the full RSC streaming window without cutting short.
	reverse_proxy ciam-athena:3000 {
		transport http {
			keepalive 65s
			keepalive_idle_conns 10
			dial_timeout 10s
			response_header_timeout 60s
			read_timeout 120s
		}
	}
}

# IAM — Internal Identity
{$IAM_HERA_PUBLIC_URL} {
	import security_headers
	reverse_proxy iam-hera:4000
}

{$IAM_HYDRA_PUBLIC_URL} {
	import security_headers
	reverse_proxy iam-hydra:7002
}

{$IAM_ATHENA_PUBLIC_URL} {
	import security_headers
	# Same RSC streaming transport settings as CIAM Athena (athena#109).
	# IAM Athena uses the same Next.js RSC architecture and is subject to
	# the same Caddy connection closure issue.
	reverse_proxy iam-athena:3000 {
		transport http {
			keepalive 65s
			keepalive_idle_conns 10
			dial_timeout 10s
			response_header_timeout 60s
			read_timeout 120s
		}
	}
}

# pgAdmin — database administration (INTERNAL ONLY — platform#21 network restriction)
#
# Network restriction evidence (AC-A1 — platform#21):
# pgAdmin MUST NOT be publicly accessible from the internet in production.
# Enforcement layers:
#   1. PGADMIN_PUBLIC_URL must resolve to a private/internal hostname only
#      (e.g., pgadmin.internal.example.com with no public DNS record)
#   2. The production server's firewall/security group MUST restrict port 443
#      (or whatever port PGADMIN_PUBLIC_URL resolves to) to authorized VPN/
#      bastion source IPs only — not 0.0.0.0/0
#   3. This Caddyfile block is intentionally present to document the routing;
#      network-layer access control is enforced at the firewall/security group,
#      not here (Caddy does not have IP allowlist for this route)
#
# OPERATOR REQUIREMENT: Before deploying, confirm firewall/security group rules
# restrict access to pgAdmin's Caddy route to internal/VPN CIDRs only.
# Failure to apply this restriction exposes all 5 Olympus PostgreSQL databases
# (including ciam_kratos, ciam_hydra, iam_kratos, iam_hydra, olympus) to the internet.
{$PGADMIN_PUBLIC_URL} {
	import security_headers
	reverse_proxy pgadmin:80
}
